ASSISTANT_NAME=
CONTAINER_IMAGE=arizuko-ant:latest
CLAUDE_CODE_OAUTH_TOKEN=
IDLE_TIMEOUT=300000
MAX_CONCURRENT_CONTAINERS=3
API_PORT=8080
CHANNEL_SECRET=
# Shared HMAC secret between proxyd and webd. Proxyd signs identity/slink
# headers; webd rejects any request whose signature doesn't verify. MUST
# be identical on both services. Generate: openssl rand -hex 32
PROXYD_HMAC_SECRET=
# CIDR allowlist of upstream proxies permitted to set X-Forwarded-For.
# Comma-separated. Default 127.0.0.1/32 trusts only a same-host proxy.
TRUSTED_PROXIES=127.0.0.1/32
TELEGRAM_BOT_TOKEN=
WEB_PORT=5173
WEB_HOST=
