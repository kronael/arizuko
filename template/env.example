ASSISTANT_NAME=
CONTAINER_IMAGE=arizuko-ant:latest
CLAUDE_CODE_OAUTH_TOKEN=
# Instance-wide default agent model when a group has no per-group override.
# Subscription models only (no usage-credit / 1M-context ids). Unset → opus.
# e.g. claude-opus-4-8 | claude-sonnet-4-6 | claude-haiku-4-5-20251001 | claude-fable-5
ARIZUKO_DEFAULT_MODEL=
IDLE_TIMEOUT=300000
MAX_CONCURRENT_CONTAINERS=3
API_PORT=8080
# AUTH_SECRET signs the web stack's HS256 session/refresh cookies (proxyd, webd).
# Generate: openssl rand -hex 32. The ES256 service tokens that authenticate
# daemon-to-daemon calls are provisioned per-daemon by `arizuko run`.
AUTH_SECRET=
# CIDR allowlist of upstream proxies permitted to set X-Forwarded-For.
# Comma-separated. Default 127.0.0.1/32 trusts only a same-host proxy.
TRUSTED_PROXIES=127.0.0.1/32
TELEGRAM_BOT_TOKEN=
WEB_PORT=5173
WEB_HOST=
